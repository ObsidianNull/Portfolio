<!--
  Wazuh Detection Rules — PowerShell Execution Policy Bypass
  MITRE ATT&CK: T1059.001 (Command and Scripting Interpreter: PowerShell)
  Data Source: Sysmon Event ID 1 (Process Creation)
  
  Rule 100100: PowerShell with -ExecutionPolicy Bypass
  Rule 100101: PowerShell with -EncodedCommand
  
  Parent SID 61603: Wazuh built-in rule for Sysmon Event ID 1
  Deploy to: /var/ossec/etc/rules/local_powershell.xml
-->

<group name="sysmon,powershell,execution,T1059.001,">

  <!-- Base detection: ExecutionPolicy Bypass -->
  <rule id="100100" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-ep\s+bypass|-executionpolicy\s+bypass)</field>
    <description>PowerShell executed with Execution Policy Bypass — T1059.001</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>attack,execution,</group>
  </rule>

  <!-- Encoded command execution — higher severity -->
  <rule id="100101" level="14">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc\s|-encodedcommand\s)</field>
    <description>PowerShell executed with Encoded Command — T1059.001</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <options>no_full_log</options>
    <group>attack,execution,</group>
  </rule>

  <!--
    Tuning: Suppress known legitimate bypass usage (example)
    Uncomment and adjust ParentImage for environment-specific exclusions.
  
  <rule id="100110" level="0">
    <if_sid>100100</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)ccmexec\.exe$</field>
    <description>Suppressed: SCCM-initiated PowerShell bypass (expected)</description>
  </rule>
  -->

</group>
